{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "routes": [
    {
      "src": "/",
      "headers": { "cache-control": "s-maxage=1000" },
      "dest": "/index.html"
    },
    {
      "src": "/favicon.ico",
      "headers": { "Cache-Control": "public, max-age=3600" },
      "dest": "/picsum.svg"
    }
  ]
}